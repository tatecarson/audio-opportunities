---
import type { Facet } from "../lib/airtable";

interface Props {
  title: string;
  /** filter dimension key, used by the client script (data-facet) */
  dim: string;
  options: Facet[];
}
const { title, dim, options } = Astro.props;
---

<div class="facet" data-facet-group={dim}>
  <button class="facet-title" type="button" data-facet-toggle aria-expanded="true">
    {title}
    <span class="facet-caret" aria-hidden="true">▾</span>
  </button>
  <div class="facet-opts">
    {
      options.map((o) => (
        <label class="facet-opt">
          <input type="checkbox" data-facet={dim} value={o.value} />
          <span class="label">{o.label}</span>
          <span class="n" data-facet-count={`${dim}:${o.value}`}>
            {o.count}
          </span>
        </label>
      ))
    }
  </div>
</div>
