---
import Base from "../layouts/Base.astro";
import Topbar from "../components/Topbar.astro";
import FacetGroup from "../components/FacetGroup.astro";
import DetailPanel from "../components/DetailPanel.astro";
import { getEmployers, getPrograms, type Employer } from "../lib/airtable";

let employers: Employer[] = [];
let facets = { sector: [] as any[], size: [] as any[], geography: [] as any[] };
let programCount = 0;
let error: string | null = null;

try {
  const data = await getEmployers();
  employers = data.employers;
  facets = data.facets;
  programCount = (await getPrograms()).programs.length;
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}

const sizeClass = (s: string) =>
  /small/i.test(s) ? "size-s" : /large/i.test(s) ? "size-l" : "size-m";
const sectorCount = facets.sector.length;
---

<Base title="Audio Directory — Employers">
  <Topbar active="employers" employerCount={employers.length} programCount={programCount} />

  {
    error ? (
      <div class="build-error">Could not load Airtable data.{"\n\n"}{error}</div>
    ) : (
      <>
      <div class="body-grid">
        <aside class="sidebar">
          <div class="sidebar-head">
            <h2>Filters</h2>
            <button class="reset" data-reset>Reset all</button>
          </div>
          <FacetGroup title="Sector" dim="sector" options={facets.sector} />
          <FacetGroup title="Company size" dim="size" options={facets.size} />
          <FacetGroup title="Hiring geography" dim="geography" options={facets.geography} />
        </aside>

        <section class="main">
          <div class="main-head">
            <div>
              <div class="count-big">{employers.length}</div>
              <h1>Audio employers</h1>
              <div class="sub">Studios, makers &amp; houses hiring audio grads</div>
              <div class="sort-toggle">
                <button data-sort="count" aria-pressed="true">Default</button>
                <button data-sort="az" aria-pressed="false">A–Z</button>
              </div>
            </div>
            <div class="stat">
              <b>{sectorCount}</b>
              sectors represented
            </div>
          </div>

          <div class="searchbar" data-searchbar>
            <span class="glyph">⌕</span>
            <input
              type="search"
              data-search-input
              placeholder="Search by company, sector, role, or keyword"
              aria-label="Search employers"
            />
            <button class="clear-search" data-search-clear>Clear</button>
          </div>

          <div class="table-wrap">
            <table class="dir" data-dims="sector,size,geography">
              <thead>
                <tr>
                  <th class="col-rank">#</th>
                  <th>Company / Sector</th>
                  <th>Headquarters</th>
                  <th>Size</th>
                  <th>Geography</th>
                </tr>
              </thead>
              <tbody>
                {employers.map((e, i) => (
                  <tr
                    class="row"
                    data-name={e.name}
                    data-search={[e.name, e.headquarters, ...e.sectors, e.roles, e.notes].join(" ").toLowerCase()}
                    data-sector={e.sectors.join("|")}
                    data-size={e.size}
                    data-geography={e.geography.join("|")}
                    data-detail={JSON.stringify({
                      title: e.name,
                      initials: e.initials,
                      url: e.careerUrl,
                      urlLabel: "Careers page ↗",
                      fields: {
                        Sector: e.sectors.join(", "),
                        Headquarters: e.headquarters,
                        "Company size": e.size,
                        "Hiring geography": e.geography.join(", "),
                        "Internship program": e.internship,
                        "Entry-level roles": e.roles,
                        "Handshake status": e.handshake,
                        Notes: e.notes,
                        "Last verified": e.lastVerified,
                      },
                    })}
                  >
                    <td class="col-rank">{String(i + 1).padStart(2, "0")}</td>
                    <td>
                      <div class="cell-co">
                        <span class="avatar">{e.initials}</span>
                        <span>
                          <span class="co-name">
                            {e.careerUrl ? (
                              <a href={e.careerUrl} target="_blank" rel="noopener">
                                {e.name}
                              </a>
                            ) : (
                              e.name
                            )}
                          </span>
                          <span class="tags">
                            {e.sectors.map((s) => (
                              <span class="tag">{s}</span>
                            ))}
                          </span>
                        </span>
                      </div>
                    </td>
                    <td class="hq">{e.headquarters || "—"}</td>
                    <td>{e.size ? <span class={`badge ${sizeClass(e.size)}`}>{e.size}</span> : "—"}</td>
                    <td>
                      <span class="geo">
                        {e.geography.length
                          ? e.geography.map((g) => <span class="badge">{g}</span>)
                          : <span class="hq">—</span>}
                      </span>
                    </td>
                  </tr>
                ))}
                <tr class="empty-row row-hidden">
                  <td colspan="5">No employers match the current filters.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <footer class="foot">
            <span class="showing">
              Showing <b data-showing>{employers.length}</b> of {employers.length} employers
            </span>
            <span>Audio Directory</span>
          </footer>
        </section>
      </div>
      <DetailPanel />
      </>
    )
  }
</Base>

<script>
  import "../scripts/directory.ts";
</script>
