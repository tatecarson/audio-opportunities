# Airtable credentials — copy this file to ".env" and fill in real values.
# See README.md → "Connecting Airtable" for how to create the token.

# Personal Access Token (starts with "pat..."). Needs scopes: data.records:read, schema.bases:read
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Base ID for the "Audio Directory" base (starts with "app")
AIRTABLE_BASE_ID=appyqRTTdm4p0Ze0P
